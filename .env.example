OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192
CONFIDENCE_THRESHOLD=0.6
SLM_TIMEOUT_SEC=30
LLM_TIMEOUT_SEC=60

# Cache
CACHE_MAX_SIZE=128
CACHE_TTL_SECONDS=300

# RAG / ChromaDB
CHROMA_PERSIST_DIR=./chroma_data
RAG_DEFAULT_TOP_K=3
RAG_ENABLED=true
